# BACKEND_URL: Hosted Meal Direct backend the /v1 proxy forwards to.
BACKEND_URL="https://mealdirectbackend.onrender.com"

# PORT: Port the server listens on. Host platforms (Render/Cloud Run) inject this.
PORT="3000"

# APP_URL: The URL where this app is hosted. Used for self-referential links.
APP_URL="MY_APP_URL"

# VITE_VAPID_PUBLIC_KEY: Web-push VAPID public key (base64url) from the backend.
# Required to enable browser push notifications. If unset, the app falls back to polling.
VITE_VAPID_PUBLIC_KEY=""
