# BACKEND_URL: Hosted Meal Direct backend the /v1 proxy forwards to.
BACKEND_URL="https://api.mealdirectly.com"

# PORT: Port the server listens on. Host platforms (Render/Cloud Run) inject this.
PORT="3000"

# APP_URL: The URL where this app is hosted. Used for self-referential links.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Browser-facing BFF API base. Defaults to /api/v1.
VITE_API_BASE_URL="/api/v1"

# VITE_VAPID_PUBLIC_KEY: Firebase Cloud Messaging "Web Push certificate" key pair —
# the public key (base64url) from Firebase Console → Project settings → Cloud Messaging.
# Passed to getToken({ vapidKey }). Required to enable browser push notifications.
# If unset, the app falls back to polling.
VITE_VAPID_PUBLIC_KEY=""

# Demo food images. When a vendor/menu item has no imageUrl (or the image fails to
# load), the app shows a placeholder. Point VITE_DEMO_IMAGE_BASE at the Supabase
# public bucket of demo pictures (e.g. .../storage/v1/object/public/demo) and the app
# will use <base>/image_1.jpg ... image_<count>.jpg. Leave empty to use a built-in
# branded placeholder (no external request).
VITE_DEMO_IMAGE_BASE=""
VITE_DEMO_IMAGE_COUNT="6"

# Sentry browser monitoring. Leave DSN empty to disable.
VITE_SENTRY_DSN=""
VITE_SENTRY_TRACES_SAMPLE_RATE="0"
VITE_APP_RELEASE=""

# Live E2E verification account. Use seeded staging/test data only.
E2E_BASE_URL=""
E2E_CUSTOMER_EMAIL=""
E2E_CUSTOMER_PASSWORD=""
